{
  "name": "node-monorepo-tools",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for @williamthorsen/nmr and related packages",
  "keywords": [],
  "homepage": "https://github.com/williamthorsen/node-monorepo-tools#readme",
  "bugs": {
    "url": "https://github.com/williamthorsen/node-monorepo-tools/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/williamthorsen/node-monorepo-tools.git"
  },
  "license": "ISC",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "bootstrap": "pnpm --filter @williamthorsen/nmr-core run prepare && pnpm --filter @williamthorsen/nmr run prepare",
    "postinstall": "node scripts/postinstall.js",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "@typescript-eslint/utils": "8.64.0",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/eslint-plugin": "1.6.23",
    "@williamthorsen/eslint-config-typescript": "6.0.2",
    "@williamthorsen/nmr": "workspace:*",
    "@williamthorsen/release-kit": "workspace:*",
    "@williamthorsen/strict-lint": "7.0.0",
    "@williamthorsen/toolbelt.objects": "3.2.8",
    "eslint": "10.7.0",
    "eslint-plugin-import": "2.32.0",
    "lefthook": "2.1.10",
    "prettier": "3.9.5",
    "readyup": "0.21.2",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "v11y-check": "workspace:*",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "zod": "4.4.3"
  },
  "packageManager": "pnpm@11.15.0",
  "engines": {
    "node": ">=24"
  }
}
