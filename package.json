{
  "name": "node-monorepo-tools",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for @williamthorsen/nmr and related packages",
  "keywords": [],
  "homepage": "https://github.com/williamthorsen/node-monorepo-tools#readme",
  "bugs": {
    "url": "https://github.com/williamthorsen/node-monorepo-tools/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/williamthorsen/node-monorepo-tools.git"
  },
  "license": "ISC",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "bootstrap": "cd packages/nmr && tsx ../../config/build.ts && tsc --project tsconfig.generate-typings.json",
    "postinstall": "node scripts/postinstall.js",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@types/eslint": "9.6.1",
    "@types/node": "24.13.1",
    "@typescript-eslint/utils": "8.60.1",
    "@typescript/native-preview": "7.0.0-dev.20260606.1",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/eslint-plugin": "1.6.19",
    "@williamthorsen/eslint-config-typescript": "5.17.5",
    "@williamthorsen/nmr": "workspace:*",
    "@williamthorsen/release-kit": "workspace:*",
    "@williamthorsen/strict-lint": "6.3.1",
    "@williamthorsen/toolbelt.objects": "3.2.6",
    "esbuild": "0.28.0",
    "eslint": "9.39.4",
    "eslint-plugin-import": "2.32.0",
    "glob": "13.0.6",
    "lefthook": "2.1.9",
    "prettier": "3.8.3",
    "readyup": "0.21.1",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.1",
    "v11y-check": "workspace:*",
    "vite": "8.0.16",
    "vitest": "4.1.8",
    "zod": "4.4.3"
  },
  "packageManager": "pnpm@10.34.1"
}
