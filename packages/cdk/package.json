{
  "name": "node-monorepo-cdk-template",
  "version": "1.3.0",
  "private": true,
  "description": "AWS CDK package template",
  "keywords": [],
  "license": "UNLICENSED",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "bin": {
    "cdk": "src/bin/AppStack.cdk.js"
  },
  "scripts": {
    "build": "pnpm run build:tsc && pnpm run build:cdk && pnpm run build:sam",
    "build:cdk": "scripts/synth.sh development",
    "build:sam": "scripts/build-sam.sh",
    "build:tsc": "tsc --build",
    "cdk": "cdk",
    "clean": "rm -rf .cdk.out/*",
    "deploy": "scripts/deploy.sh",
    "destroy": "scripts/destroy.sh",
    "dev": "pnpm run build && pnpm start",
    "start": "sam local start-api --port 3001 --debug --profile skypilot --warm-containers EAGER",
    "synth": "scripts/synth.sh",
    "ws": "node --import tsx ../../scripts/run-workspace-script.ts --int-test"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "3.1004.0",
    "@aws-sdk/client-s3": "3.1004.0",
    "@aws-sdk/client-ssm": "3.1004.0",
    "aws-cdk-lib": "2.241.0",
    "constructs": "10.5.1",
    "source-map-support": "0.5.21"
  },
  "devDependencies": {
    "@types/aws-lambda": "8.10.161",
    "aws-cdk": "2.1109.0",
    "aws-sdk-client-mock": "4.1.0"
  }
}
