{
  "name": "node-monorepo-chrome-template",
  "version": "1.3.0",
  "private": true,
  "description": "Chrome extension template",
  "keywords": [],
  "license": "UNLICENSED",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "scripts": {
    "build": "pnpm run build:esm && pnpm run build:iife",
    "build:esm": "pnpm vite build",
    "build:iife": "pnpm vite build --config vite.iife.config.js",
    "dev": "pnpm vite --host",
    "preview": "pnpm vite preview",
    "ws": "node --import tsx ../../scripts/run-workspace-script.ts"
  },
  "dependencies": {
    "@williamthorsen/toolbelt.guards": "3.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/chrome": "0.1.37",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "eslint-plugin-react": "7.37.5",
    "jsdom": "28.1.0"
  }
}
