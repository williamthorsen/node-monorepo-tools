{
  "name": "@williamthorsen/node-monorepo-core",
  "version": "0.1.1",
  "private": false,
  "description": "Context-aware script runner for PNPM monorepos",
  "keywords": [
    "monorepo",
    "pnpm",
    "script-runner",
    "workspace"
  ],
  "license": "MIT",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "exports": {
    ".": "./dist/esm/index.js",
    "./tests": "./dist/esm/tests/consistency.js"
  },
  "bin": {
    "nmr": "dist/esm/cli.js",
    "nmr-report-overrides": "dist/esm/cli-report-overrides.js",
    "nmr-sync-pnpm-version": "dist/esm/cli-sync-pnpm-version.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "pnpm run ws build",
    "ws": "node --import tsx ../../scripts/run-workspace-script.ts"
  },
  "dependencies": {
    "jiti": "2.6.1",
    "js-yaml": "4.1.1",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "vitest": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
