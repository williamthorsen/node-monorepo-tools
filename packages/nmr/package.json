{
  "name": "@williamthorsen/nmr",
  "version": "0.19.0",
  "private": false,
  "description": "Context-aware script runner for PNPM monorepos",
  "keywords": [
    "monorepo",
    "pnpm",
    "script-runner",
    "workspace"
  ],
  "homepage": "https://github.com/williamthorsen/node-monorepo-tools/tree/main/packages/nmr#readme",
  "bugs": {
    "url": "https://github.com/williamthorsen/node-monorepo-tools/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/williamthorsen/node-monorepo-tools.git",
    "directory": "packages/nmr"
  },
  "license": "ISC",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "default": "./dist/esm/index.js"
    },
    "./scripts": {
      "types": "./dist/esm/scripts.d.ts",
      "default": "./dist/esm/scripts.js"
    },
    "./taze": {
      "types": "./dist/esm/taze.d.ts",
      "default": "./dist/esm/taze.js"
    },
    "./workspace": {
      "types": "./dist/esm/workspace.d.ts",
      "default": "./dist/esm/workspace.js"
    }
  },
  "bin": {
    "ensure-prepublish-hooks": "bin/ensure-prepublish-hooks.js",
    "nmr": "bin/nmr.js",
    "nmr-clean": "bin/nmr-clean.js",
    "nmr-compile": "bin/nmr-compile.js",
    "nmr-report-overrides": "bin/nmr-report-overrides.js",
    "nmr-sync-agent-files": "bin/nmr-sync-agent-files.js",
    "nmr-taze": "bin/nmr-taze.js"
  },
  "files": [
    "AGENTS.md",
    "bin",
    "dist"
  ],
  "scripts": {
    "build:post": "nmr-sync-agent-files",
    "prepare": "tsx src/cli-build.ts"
  },
  "dependencies": {
    "@williamthorsen/nmr-core": "workspace:*",
    "glob": "13.0.6",
    "jiti": "2.7.0",
    "taze": "19.15.1",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@williamthorsen/toolbelt.strings": "3.1.6"
  },
  "peerDependencies": {
    "typescript": ">=5.7.0 <7"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
